#!/usr/bin/env bash
# Смена пароля роли postgres без запроса старого пароля (локальное подключение peer).
# Только для root. В пакете .deb: каталог compose — /usr/share/vvz-1csrv-postgres.
set -euo pipefail

if [[ "$(id -u)" -ne 0 ]]; then
  echo "pg1cchkpwd: требуются права root (sudo)." >&2
  exit 1
fi

escape_sq() {
  printf '%s' "$1" | sed "s/'/''/g"
}

for f in /etc/default/pgsql1c-stack /etc/default/vvz-1csrv-postgres; do
  if [[ -f "$f" ]]; then
    set -a
    # shellcheck source=/dev/null
    source "$f"
    set +a
  fi
done
# COMPOSE_PROJECT_DIR из /etc/default/pgsql1c-stack (пакет / systemd); иначе каталог с compose в репозитории или путь пакета
if [[ -z "${COMPOSE_PROJECT_DIR:-}" ]]; then
  if [[ -f "$(pwd)/docker-compose.yml" ]]; then
    COMPOSE_PROJECT_DIR=$(pwd)
  else
    COMPOSE_PROJECT_DIR=/usr/share/vvz-1csrv-postgres
  fi
fi
SHARE="$COMPOSE_PROJECT_DIR"
export PGSQL1C_VAR="${PGSQL1C_VAR:-/var/pgsql1c}"
export PGSQL1C_LOG="${PGSQL1C_LOG:-/var/log/pgsql1c}"
export PGSQL1C_ETC="${PGSQL1C_ETC:-/etc/pgsql1c}"
export PGSQL1C_DOCKER_SUBNET="${PGSQL1C_DOCKER_SUBNET:-172.31.0.0/16}"
export PGSQL1C_CONTAINER_IP="${PGSQL1C_CONTAINER_IP:-172.31.0.2}"
export PGSQL1C_PGHBA_MODE="${PGSQL1C_PGHBA_MODE:-managed}"
export VVZ_IMAGE="${VVZ_IMAGE:-docker.io/vasilyvz/vvz-1csrv-postgres:latest}"
export ONEC_HOSTNAME="${ONEC_HOSTNAME:-e874b7de82cd}"

if [[ -n "${PGSQL1C_POSTGRES_PASSWORD:-}" ]]; then
  PW="$PGSQL1C_POSTGRES_PASSWORD"
elif [[ -n "${1:-}" ]]; then
  PW="$1"
elif [[ ! -t 0 ]]; then
  read -r PW
else
  read -r -s -p "Новый пароль для пользователя postgres: " PW
  echo
fi

if [[ -z "${PW}" ]]; then
  echo "pg1cchkpwd: пароль пустой." >&2
  exit 1
fi

PWSQL=$(escape_sq "$PW")
cd "$SHARE"

exec docker compose -f docker-compose.yml exec -T app runuser -u postgres -- \
  /opt/pgpro/std-16/bin/psql -v ON_ERROR_STOP=1 -c "ALTER USER postgres WITH PASSWORD '${PWSQL}';"
